---
import ColorSwatches from './ColorSwatches.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
  currency?: string;
}
const { product, currency = '$' } = Astro.props;
const { name, images, colors, prices, category, soldOut } = product.data;

const cover = images[0];
const lowest =
  prices.length > 0 ? Math.min(...prices.map((p) => p.price)) : null;
const href = `/producto/${product.slug}/`;
---

<article class="card">
  <a class="card-media" href={href}>
    <img src={cover} alt={name} loading="lazy" width="600" height="750" />
    {soldOut && <span class="badge card-badge">Agotado</span>}
  </a>

  <div class="card-body">
    {category && <p class="eyebrow card-cat">{category}</p>}
    <h3 class="card-name">
      <a href={href}>{name}</a>
    </h3>

    {colors.length > 0 && <ColorSwatches colors={colors} />}

    {
      lowest !== null && (
        <p class="card-price">
          Desde <strong>{currency}{lowest}</strong>
        </p>
      )
    }
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
  }

  .card-media {
    position: relative;
    display: block;
    overflow: hidden;
    background: var(--color-paper-2);
    aspect-ratio: 4 / 5;
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .card-media:hover img {
    transform: scale(1.04);
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
  }

  .card-body {
    padding: 0.95rem 0.2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-cat {
    margin: 0;
    font-size: 0.66rem;
  }

  .card-name {
    font-size: 1.35rem;
    line-height: 1.15;
  }

  .card-price {
    margin: 0.1rem 0 0;
    font-size: 0.9rem;
    color: var(--color-soft);
  }
  .card-price strong {
    color: var(--color-ink);
    font-weight: 500;
  }
</style>
