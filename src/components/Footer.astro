---
interface Props {
  settings?: {
    whatsappNumber: string;
    instagramHandle: string;
  };
}
const { settings } = Astro.props;
const ig = settings?.instagramHandle;
const wa = settings?.whatsappNumber;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img src="/logo.jpg" alt="" width="56" height="56" class="footer-mark" />
      <p class="footer-tagline">Ropa deportiva para mujer</p>
    </div>

    <nav class="footer-contact" aria-label="Contacto">
      {
        ig && (
          <a href={`https://instagram.com/${ig}`} target="_blank" rel="noopener noreferrer">
            Instagram @{ig}
          </a>
        )
      }
      {
        wa && (
          <a href={`https://wa.me/${wa}`} target="_blank" rel="noopener noreferrer">
            WhatsApp
          </a>
        )
      }
    </nav>
  </div>

  <div class="container footer-legal">
    <span>© {year} Yulistore</span>
    <span>Hecho con cariño en Venezuela</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    border-top: 1px solid var(--color-line);
    background: var(--color-paper-2);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    align-items: center;
    justify-content: space-between;
    padding-top: 3rem;
    padding-bottom: 2rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-mark {
    width: 56px;
    height: 56px;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .footer-tagline {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-soft);
  }

  .footer-contact {
    display: flex;
    gap: 1.6rem;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-contact a {
    color: var(--color-soft);
    transition: color 0.2s ease;
  }
  .footer-contact a:hover {
    color: var(--color-ink);
  }

  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: space-between;
    padding-bottom: 2rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--color-soft);
  }
</style>
